API_PORT=13000
CHAT_PORT=18080
GATEWAY_PORT=14000
OTEL_GRPC_PORT=14317
OTEL_HTTP_PORT=14318
POSTGRES_PORT=15432
PGBOUNCER_PORT=16432
REDIS_PORT=16379
MINIO_PORT=19000
MINIO_CONSOLE_PORT=19001

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=stripnoir
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=50

JWT_SECRET=dev_jwt_secret
JWT_ACCESS_SECRET=dev_access_secret
JWT_REFRESH_SECRET=dev_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CHAT_INTERNAL_API_KEY=

# Phase 6 (optional): Node delegates hot paths to Go chat internal HTTP (chat needs DATABASE_URL in compose).
# CHAT_HISTORY_DELEGATE=1
# CHAT_HISTORY_SHADOW=1
# LIVE_AGGREGATE_DELEGATE=1

# Phase 7 (optional): Node read replica URL (PgBouncer *_ro alias). See docs/operations/Phase7_Multi_Region_and_Reliability.md
# DATABASE_READ_URL=

# API: allow POST /api/v1/creators/subscription without payment (default off in production)
# ALLOW_FREE_SUBSCRIPTION=1

# Phase 7: optional catalog enforcement
# When enabled, public/followers visibility is treated as subscriber-only in discovery feeds.
# SUBSCRIBERS_ONLY_CATALOG=1

# Expose Prometheus-style /metrics on api + chat (set 0 to disable)
METRICS_ENABLED=1

# Optional: nginx edge gateway — docker compose --profile gateway up -d gateway
# When browsers use the gateway for WS, set API CHAT_PUBLIC_URL to the same public origin, e.g.:
# CHAT_PUBLIC_URL=http://localhost:14000

# PgBouncer optional read replica (second database alias in pgbouncer.ini)
# PGBOUNCER_REPLICA_HOST=
# PGBOUNCER_REPLICA_ALIAS=stripnoir_ro

# Worker (docker compose --profile worker up -d worker)
# WORKER_NOTIFICATION_QUEUE=stripnoir:queue:notifications
# WORKER_POLL_BLOCK_SEC=5

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# S3-compatible presigned upload URL generation for the API.
# The endpoint must be reachable by the client that will perform the PUT.
MINIO_ENDPOINT=http://localhost:19000
MINIO_BUCKET=stripnoir
MINIO_REGION=us-east-1
