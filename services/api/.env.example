PORT=3000
JWT_SECRET=dev_jwt_secret
JWT_ACCESS_SECRET=dev_access_secret
JWT_REFRESH_SECRET=dev_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CHAT_SERVICE_URL=http://chat:8080
# Browser-facing WS/long-poll base (omit to use CHAT_SERVICE_URL). Required behind public nginx gateway.
CHAT_PUBLIC_URL=
CHAT_INTERNAL_API_KEY=
# Phase 6: optional delegation to Go internal APIs (same DB/Redis as Node). Requires chat with DATABASE_URL.
# CHAT_HISTORY_DELEGATE=1
# CHAT_HISTORY_SHADOW=1
# LIVE_AGGREGATE_DELEGATE=1
DATABASE_URL=postgresql://app:app@postgres:5432/stripnoir
# Phase 7: optional read replica via PgBouncer alias (e.g. stripnoir_ro). Omit to use primary only.
# DATABASE_READ_URL=

# When unset/false, POST /api/v1/creators/subscription returns 403 (use /payments/subscribe for paid subs).
# ALLOW_FREE_SUBSCRIPTION=1

# Phase 7: optional catalog enforcement
# When enabled, public/followers visibility is treated as subscriber-only in discovery feeds.
# SUBSCRIBERS_ONLY_CATALOG=1

# MinIO/S3 upload support (presigned PUT URLs for uploads)
# The endpoint must be reachable by the client performing the PUT.
MINIO_ENDPOINT=http://localhost:19000
MINIO_BUCKET=stripnoir
MINIO_REGION=us-east-1
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

REDIS_URL=redis://redis:6379

# Rate limiting (Redis fixed window; set TRUST_PROXY when behind a reverse proxy)
TRUST_PROXY=
TRUST_PROXY_HOPS=1
API_RATE_LIMIT_WINDOW_SEC=60
API_RATE_LIMIT_MAX=200
API_AUTH_RATE_LIMIT_WINDOW_SEC=900
API_AUTH_RATE_LIMIT_MAX=40
API_AUTH_RATE_LIMIT_ENABLED=true

# Prometheus-style GET /metrics and GET /metrics.json (off unless true/1)
METRICS_ENABLED=
